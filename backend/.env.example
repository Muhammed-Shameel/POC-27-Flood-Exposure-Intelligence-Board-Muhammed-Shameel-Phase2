# Backend Environment Configuration

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# Data Mode
# Options: mock, hybrid, live
DATA_MODE=live

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "*"]

# External API Keys (for live mode)
WEATHER_API_KEY=your_weather_api_key_here
GIS_API_KEY=your_gis_api_key_here
