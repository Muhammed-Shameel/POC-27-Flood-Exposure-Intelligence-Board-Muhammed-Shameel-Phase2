# Flood Intelligence Board - Environment Configuration

# --- BACKEND SETTINGS ---
DATA_MODE=live
LOG_LEVEL=INFO

# External API Keys (Optional - for live mode)
WEATHER_API_KEY=your_weather_api_key_here
GIS_API_KEY=your_gis_api_key_here

# --- FRONTEND SETTINGS ---
# For local Docker, this should point to the backend container's exposed port
NEXT_PUBLIC_API_URL=https://flood-exposure-intelligence-board.onrender.com

# Mapbox (Optional - if you decide to use it)
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here
